# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Gemini AI — single key
GEMINI_API_KEY=

# Gemini AI — multiple keys pool (comma-separated, auto-rotates on quota exhaustion)
# Example: GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=

# Mistral AI — multiple keys pool (comma-separated, used as fallback when Gemini exhausted)
# Example: MISTRAL_API_KEYS=key1,key2,key3
MISTRAL_API_KEYS=

# Neon Database
DATABASE_URL=

# App Settings
APP_PORT=3000
BUSY_MODE=true

# Telegram Bot (Mujtaba ko updates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
