# WhatsApp Cloud API (legacy, not used with Baileys)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Gemini AI — single key (legacy)
GEMINI_API_KEY=

# Gemini AI — multiple keys pool (comma-separated)
# Get free keys: https://aistudio.google.com/apikey
GEMINI_API_KEYS=

# Mistral AI — multiple keys pool (comma-separated)
# Get free keys: https://console.mistral.ai/api-keys/
MISTRAL_API_KEYS=

# Groq AI — multiple keys pool (comma-separated)
# Get free keys: https://console.groq.com/keys
GROQ_API_KEYS=

# OpenRouter AI — multiple keys pool (comma-separated)
# Get free keys: https://openrouter.ai/keys
OPENROUTER_API_KEYS=

# DeepSeek AI — multiple keys pool (comma-separated)
# Get free keys: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEYS=

# Neon Database
DATABASE_URL=

# App Settings
APP_PORT=3000
BUSY_MODE=true

# Telegram Bot (Mujtaba ko updates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
